// ==========================================
// 1. GENERAL SETTINGS (UI, Behavior, System)
// ==========================================

// Change your default shell (e.g., "zsh", "bash", "fish")
// default_shell "zsh" 

// Choose your color theme (e.g., "default", "catppuccin-mocha", "dracula", "nord")
theme "catppuccin-mocha"

// Turn off borders around panes to save screen space (true or false)
pane_frames false

// Enable clicking and scrolling with your mouse (true or false)
mouse_mode true

// Copy text automatically when you highlight it with the mouse (true or false)
copy_on_select true

// How many lines of history Zellij remembers per pane
scroll_buffer_size 10000

// Don't show the initial tips screen when starting Zellij
show_startup_tips false

// Remove arrow fonts in the UI if your terminal doesn't support them
simplified_ui true


// ==========================================
// 2. KEYBINDINGS (From Scratch)
// ==========================================

keybinds clear-defaults=true {
    
    // --- NORMAL MODE (Your starting point) ---
    // Use this to define the keys that TAKE you to other modes
    normal {
        bind "Ctrl p" { SwitchToMode "pane"; }     // Enter Pane mode
        bind "Ctrl t" { SwitchToMode "tab"; }      // Enter Tab mode
        bind "Ctrl r" { SwitchToMode "resize"; }   // Enter Resize mode
        bind "Ctrl h" { SwitchToMode "move"; }     // Enter Move mode
        bind "Ctrl o" { SwitchToMode "session"; }  // Enter Session/Plugin mode
        bind "Ctrl g" { SwitchToMode "locked"; }   // Enter Locked mode (ignores all shortcuts)
        bind "Ctrl q" { Quit; }                    // Quit Zellij entirely
    }

    // --- LOCKED MODE ---
    // Perfect for when you use Vim/Emacs inside Zellij and need Zellij to get out of the way
    locked {
        bind "Ctrl g" { SwitchToMode "normal"; }   // The ONLY key that works: Unlock and return to Normal
    }

    // --- PANE MODE (Managing splits and windows) ---
    pane {
        bind "n" { NewPane; SwitchToMode "normal"; }          // Create a new pane automatically
        bind "d" { NewPane "down"; SwitchToMode "normal"; }   // Split pane horizontally (bottom)
        bind "r" { NewPane "right"; SwitchToMode "normal"; }  // Split pane vertically (right)
        bind "x" { CloseFocus; SwitchToMode "normal"; }       // Close the current pane
        bind "f" { ToggleFocusFullscreen; SwitchToMode "normal"; } // Make current pane full screen
        bind "w" { ToggleFloatingPanes; SwitchToMode "normal"; }   // Pop pane out to float
        bind "e" { TogglePaneEmbedOrFloating; SwitchToMode "normal"; } // Toggle float/embed
        bind "c" { SwitchToMode "renamepane"; PaneNameInput 0; }   // Rename the current pane
        
        // Move your cursor between panes
        bind "left" "h" { MoveFocus "left"; }
        bind "right" "l" { MoveFocus "right"; }
        bind "up" "k" { MoveFocus "up"; }
        bind "down" "j" { MoveFocus "down"; }
    }

    // --- TAB MODE (Managing tabs at the top) ---
    tab {
        bind "n" { NewTab; SwitchToMode "normal"; }           // Create a new tab
        bind "x" { CloseTab; SwitchToMode "normal"; }         // Close the current tab
        bind "r" { SwitchToMode "renametab"; TabNameInput 0; }// Rename the current tab
        bind "b" { BreakPane; SwitchToMode "normal"; }        // Move current pane to its own new tab
        
        // Move between your tabs
        bind "left" "h" { GoToPreviousTab; }
        bind "right" "l" { GoToNextTab; }
        bind "1" { GoToTab 1; SwitchToMode "normal"; }        // Jump straight to Tab 1
        bind "2" { GoToTab 2; SwitchToMode "normal"; }        // Jump straight to Tab 2
    }

    // --- RESIZE MODE (Changing pane sizes) ---
    resize {
        bind "left" "h" { Resize "Increase left"; }   // Push border left
        bind "right" "l" { Resize "Increase right"; } // Push border right
        bind "up" "k" { Resize "Increase up"; }       // Push border up
        bind "down" "j" { Resize "Increase down"; }   // Push border down
        bind "+" "=" { Resize "Increase"; }           // Make current pane bigger overall
        bind "-" { Resize "Decrease"; }               // Make current pane smaller overall
    }

    // --- MOVE MODE (Swapping pane positions) ---
    move {
        bind "n" "tab" { MovePane; }                  // Cycle pane position forward
        bind "p" { MovePaneBackwards; }               // Cycle pane position backward
        bind "left" "h" { MovePane "left"; }          // Swap pane to the left
        bind "right" "l" { MovePane "right"; }        // Swap pane to the right
        bind "up" "k" { MovePane "up"; }              // Swap pane up
        bind "down" "j" { MovePane "down"; }          // Swap pane down
    }

    // // --- SCROLL MODE (Looking back at past terminal output) ---
    // scroll {
    //     bind "down" "j" { ScrollDown; }               // Scroll down one line
    //     bind "up" "k" { ScrollUp; }                   // Scroll up one line
    //     bind "PageDown" "right" "l" { PageScrollDown; } // Scroll down a full page
    //     bind "PageUp" "left" "h" { PageScrollUp; }      // Scroll up a full page
    //     bind "e" { EditScrollback; SwitchToMode "normal"; } // Open terminal history in your text editor
    //     bind "s" { SwitchToMode "entersearch"; SearchInput 0; } // Search terminal history for text
    // }
    //
    // // --- SEARCH MODE (Finding text in the scrollback) ---
    // search {
    //     bind "n" { Search "down"; }                   // Find next matching word
    //     bind "p" { Search "up"; }                     // Find previous matching word
    //     bind "c" { SearchToggleOption "CaseSensitivity"; } // Toggle case sensitive search
    //     bind "w" { SearchToggleOption "WholeWord"; }  // Toggle whole word search
    // }

    // --- SESSION MODE (Managing Zellij background sessions) ---
    session {
        bind "d" { Detach; }                          // Leave Zellij running in background and return to main terminal
        bind "w" { LaunchOrFocusPlugin "session-manager" { floating true; move_to_focused_tab true; }; SwitchToMode "normal"; } // Open visual session manager
    }

    // ==========================================
    // 3. SHARED SHORTCUTS (Apply everywhere)
    // ==========================================
    
    // THE ESCAPE HATCH: Pressing Escape takes you back to normal typing from anywhere
    shared_except "normal" "locked" {
        bind "esc" { SwitchToMode "normal"; }
    }

    shared_except "locked" {
        bind "Alt left" "Alt h" { MoveFocusOrTab "left"; }    // Jump left 
        bind "Alt right" "Alt l" { MoveFocusOrTab "right"; }  // Jump right
        bind "Alt down" "Alt j" { MoveFocus "down"; }         // Jump down 
        bind "Alt up" "Alt k" { MoveFocus "up"; }             // Jump up 
        bind "Alt f" { ToggleFloatingPanes; }                 // Quick toggle float
    }
}

// ==========================================
// 4. PLUGINS (Core UI Elements)
// ==========================================
plugins {
    tab-bar location="zellij:tab-bar"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    compact-bar location="zellij:compact-bar"
    session-manager location="zellij:session-manager"
}
