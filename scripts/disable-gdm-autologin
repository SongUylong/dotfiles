#!/usr/bin/env python3
"""Remove GDM automatic login lines from /etc/gdm/custom.conf."""
from __future__ import annotations

import re
import shutil
import sys
from datetime import datetime, timezone
from pathlib import Path

CONF = Path("/etc/gdm/custom.conf")


def strip_autologin_lines(text: str) -> str:
    out = []
    for line in text.splitlines(True):
        if re.match(r"^\s*AutomaticLogin(Enable)?=", line):
            continue
        out.append(line)
    return "".join(out)


def main() -> int:
    try:
        import os

        if os.geteuid() != 0:
            print("Run as root: sudo " + " ".join(sys.argv), file=sys.stderr)
            return 1
    except AttributeError:
        pass

    if not CONF.is_file():
        print(f"Missing {CONF}", file=sys.stderr)
        return 1

    raw = CONF.read_text(encoding="utf-8", errors="replace")
    ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    backup = CONF.with_name(f"custom.conf.bak.{ts}")
    shutil.copy2(CONF, backup)
    print(f"Backup: {backup}")

    merged = strip_autologin_lines(raw)
    CONF.write_text(merged, encoding="utf-8")
    print(f"Removed automatic login from {CONF}")
    print("Reboot or: sudo systemctl restart gdm.service")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
