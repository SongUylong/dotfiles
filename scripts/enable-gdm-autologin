#!/usr/bin/env python3
"""Enable GDM automatic login by merging into /etc/gdm/custom.conf."""
from __future__ import annotations

import re
import shutil
import sys
from datetime import datetime, timezone
from pathlib import Path

CONF = Path("/etc/gdm/custom.conf")


def strip_autologin_lines(text: str) -> str:
    out = []
    for line in text.splitlines(True):
        if re.match(r"^\s*AutomaticLogin(Enable)?=", line):
            continue
        out.append(line)
    return "".join(out)


def insert_autologin(text: str, user: str) -> str:
    lines = text.splitlines(True)
    out: list[str] = []
    i = 0
    inserted = False
    while i < len(lines):
        line = lines[i]
        out.append(line)
        if line.strip() == "[daemon]" and not inserted:
            out.append("AutomaticLoginEnable=true\n")
            out.append(f"AutomaticLogin={user}\n")
            inserted = True
        i += 1
    if not inserted:
        if not text.endswith("\n") and text:
            out.append("\n")
        out.append("[daemon]\n")
        out.append("AutomaticLoginEnable=true\n")
        out.append(f"AutomaticLogin={user}\n")
    return "".join(out)


def main() -> int:
    if len(sys.argv) != 2:
        print(f"Usage: sudo {sys.argv[0]} USERNAME", file=sys.stderr)
        return 1
    user = sys.argv[1]
    if not re.fullmatch(r"[a-z_][a-z0-9_-]*", user, re.I):
        print("Refusing: username looks invalid.", file=sys.stderr)
        return 1

    try:
        import os

        if os.geteuid() != 0:
            print("Run as root: sudo " + " ".join(sys.argv), file=sys.stderr)
            return 1
    except AttributeError:
        pass

    if not CONF.is_file():
        print(f"Missing {CONF} — is GDM installed?", file=sys.stderr)
        return 1

    raw = CONF.read_text(encoding="utf-8", errors="replace")
    ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    backup = CONF.with_name(f"custom.conf.bak.{ts}")
    shutil.copy2(CONF, backup)
    print(f"Backup: {backup}")

    cleaned = strip_autologin_lines(raw)
    merged = insert_autologin(cleaned, user)
    CONF.write_text(merged, encoding="utf-8")
    print(f"Wrote {CONF}")
    print("Automatic login enabled for:", user)
    print("Reboot or restart GDM: sudo systemctl restart gdm.service")
    print("(You will be disconnected from the graphical session.)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
