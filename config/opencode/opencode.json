{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax/minimax-m2.5-free",
  "permission": {
    "bash": "ask", // Asks for confirmation before running terminal commands
    "edit": "allow" // Allows OpenCode to edit files automatically
  },
  "mcp": {
    "vercel": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://mcp.vercel.com"]
    },
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.notion.com/mcp"],
      "enabled": true
    }, // 4. PUPPETEER: Lets OpenCode spin up a headless browser to test your web app UI
    "puppeteer": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-puppeteer"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "default_agent": "build",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "deepseek-coder:6.7b": {
          "name": "DeepSeek Coder 6.7B",
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}
